{
  "name": "video-hub-app-sin",
  "productName": "Video Hub App SIN",
  "version": "3.3.0-sin.7",
  "description": "Video Hub App SIN - an unsupported personal fork for browsing, searching, previewing, and managing videos",
  "homepage": "https://github.com/sebiimaks/Video-Hub-App-SIN",
  "repository": {
    "type": "git",
    "url": "https://github.com/sebiimaks/Video-Hub-App-SIN.git"
  },
  "author": {
    "name": "Boris Yakubchik",
    "email": "yboris@yahoo.com"
  },
  "contributors": [
    {
      "name": "Cal Martin",
      "url": "https://github.com/cal2195"
    },
    {
      "name": "sebiimaks",
      "email": "github.sadness446@passmail.net",
      "url": "https://github.com/sebiimaks"
    }
  ],
  "keywords": [
    "video"
  ],
  "main": "main.js",
  "license": "MIT",
  "engines": {
    "node": ">=v18"
  },
  "scripts": {
    "start": "npm-run-all -p electron:serve ng:serve",
    "build": "npm run electron:serve-tsc && ng build --base-href ./",
    "build:prod": "npm run build -- -c production",
    "buildsize": "sh ./bin/buildSizeCheck.sh",
    "check": "npm run check:tsc && npm run check:lint",
    "check:lint": "ng lint --quiet",
    "check:tsc": "tsc --project ./tsconfig.json --noEmit && tsc --project ./tsconfig-serve.json --noEmit && tsc --project ./tsconfig.worker.json --noEmit",
    "hasRemote": "sh ./bin/hasRemoteCheck.sh",
    "electron": "npm run hasRemote && npm run media:prepare && npm run build:prod && electron-builder build && npm run media:source && npm run buildsize",
    "electron:mac:release": "npm run hasRemote && npm run media:prepare && npm run build:prod && electron-builder build --mac dmg --arm64 && npm run media:source && npm run buildsize",
    "electron:mac:test": "npm run hasRemote && npm run media:prepare && npm run build:prod && electron-builder build --mac dir --arm64 --config.directories.output=release-test && npm run media:source:test && npm run verify:mac:test",
    "electron:serve": "wait-on tcp:4200 && npm run electron:serve-tsc && npx electron . --serve",
    "electron:serve-tsc": "tsc -p tsconfig-serve.json",
    "ng": "ng",
    "lint": "ng lint",
    "legal:generate": "node ./bin/generate-third-party-notices.mjs",
    "media:build": "sh ./bin/build-media-tools.sh",
    "media:ensure": "sh ./bin/ensure-media-tools.sh",
    "media:prepare": "npm run media:ensure && npm run legal:generate",
    "media:source": "sh ./bin/package-media-source.sh",
    "media:source:test": "sh ./bin/package-media-source.sh ./release-test",
    "ng:serve": "ng serve",
    "postinstall": "electron-builder install-app-deps",
    "test": "npm-run-all -s test:persistence test:local-safety test:media-toolchain",
    "test:local-safety": "ts-node --project tsconfig.persistence-tests.json node/local-operation-safety.test.ts",
    "test:media-toolchain": "ts-node --project tsconfig.persistence-tests.json node/media-toolchain.test.ts",
    "test:persistence": "ts-node --project tsconfig.persistence-tests.json node/vha-file-persistence.test.ts",
    "verify:mac:test": "node ./bin/verify-packaged-app.mjs './release-test/mac-arm64/Video Hub App SIN.app'"
  },
  "dependencies": {
    "@iharbeck/ngx-virtual-scroller": "19.0.1",
    "@ngx-translate/core": "17.0.0",
    "an-qrcode": "1.0.7",
    "async": "3.2.6",
    "body-parser": "2.2.0",
    "chokidar": "4.0.3",
    "electron-window-state": "5.0.3",
    "express": "5.1.0",
    "fdir": "6.5.0",
    "fuse.js": "7.1.0",
    "ip": "2.0.1",
    "natural-orderby": "5.0.0",
    "object-hash": "^3.0.0",
    "path": "0.12.7",
    "trash": "7.2.0",
    "tslib": "2.8.1",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.7",
    "@angular-eslint/builder": "20.4.0",
    "@angular-eslint/schematics": "20.4.0",
    "@angular/animations": "20.3.7",
    "@angular/cdk": "20.2.10",
    "@angular/cli": "20.3.7",
    "@angular/common": "20.3.7",
    "@angular/compiler": "20.3.7",
    "@angular/compiler-cli": "20.3.7",
    "@angular/core": "20.3.7",
    "@angular/forms": "20.3.7",
    "@angular/material": "20.2.10",
    "@angular/platform-browser": "20.3.7",
    "@angular/platform-browser-dynamic": "20.3.7",
    "@angular/router": "20.3.7",
    "@tweenjs/tween.js": "25.0.0",
    "@types/node": "24.9.1",
    "@typescript-eslint/eslint-plugin": "8.46.2",
    "@typescript-eslint/parser": "8.46.2",
    "baseline-browser-mapping": "2.10.37",
    "electron": "42.4.0",
    "electron-builder": "26.15.3",
    "electron-reload": "1.5.0",
    "eslint": "8.57.1",
    "npm-run-all": "4.1.5",
    "rxjs": "7.8.2",
    "stylelint": "16.25.0",
    "stylelint-config-recommended-scss": "16.0.2",
    "stylelint-order": "7.0.0",
    "stylelint-scss": "6.12.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "wait-on": "9.0.1",
    "zone.js": "0.15.1"
  },
  "overrides": {
    "minimatch": "5.1.2",
    "glob": "8.1.0"
  },
  "optionalDependencies": {
    "dmg-license": "1.0.11"
  },
  "browserslist": [
    "chrome 140"
  ]
}
