{
  "productName": "Video Hub App SIN",
  "appId": "com.github.sebiimaks.videohubappsin",
  "copyright": "Copyright © 2022 Boris Yakubchik",
  "directories": {
    "output": "release/"
  },
  "files": [
    "dist/**/*",
    "main.js",
    "node/**/*.js",
    "interfaces/**/*.js",
    "i18n/*.json"
  ],
  "extraResources": [
    {
      "from": "LICENSE",
      "to": "LICENSE"
    },
    {
      "from": "src/assets/icons/mac/touch-bar",
      "to": "assets"
    },
    {
      "from": "remote",
      "to": "remote"
    },
    {
      "from": "src/assets/logo.png",
      "to": "assets/logo.png"
    }
  ],
  "win": {
    "icon": "dist/favicon",
    "asar": true,
    "asarUnpack": [
      "../node_modules/ffmpeg-static",
      "../node_modules/node-ffprobe-installer"
    ],
    "target": [
      "nsis",
      "portable"
    ]
  },
  "mac": {
    "category": "public.app-category.video",
    "artifactName": "video-hub-app-sin-v${version}-${arch}.${ext}",
    "target": {
      "target": "dmg",
      "arch": [
        "x64",
        "arm64"
      ]
    },
    "icon": "src/assets/icons.icns",
    "asar": true,
    "asarUnpack": [
      "../node_modules/ffmpeg-static",
      "../node_modules/node-ffprobe-installer"
    ]
  },
  "linux": {
    "icon": "src/assets/icons/png",
    "category": "AudioVideo",
    "synopsis": "Unsupported personal fork of Video Hub App 3",
    "description": "Browse, search, preview, and manage video collections. This is an unsupported personal version of the Video Hub App. All changes made utilising LLMs. Use at your own risk.",
    "maintainer": "sebiimaks <github.sadness446@passmail.net>",
    "vendor": "sebiimaks",
    "desktop": {
      "entry": {
        "Name": "Video Hub App SIN",
        "Comment": "Browse, search, preview, and manage video collections",
        "Categories": "AudioVideo;Video;"
      }
    },
    "target": [
      "AppImage",
      "deb"
    ]
  },
  "deb": {
    "packageName": "video-hub-app-sin",
    "packageCategory": "video",
    "priority": "optional"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true
  },
  "fileAssociations": {
    "ext": "vha2",
    "name": "Video Hub App SIN file",
    "role": "Editor"
  }
}
